# Copy to .env and fill in real values. .env is gitignored.

# Local dev default; on EC2 point at the RDS instance's sensor_db database.
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/sensor_db

# development | production
ENVIRONMENT=development

# Phase 2: S3 data lake bucket for Parquet archives
AWS_REGION=ap-south-1
S3_BUCKET_NAME=
